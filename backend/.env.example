DJANGO_ENV=development
SECRET_KEY=change-me-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,10.0.2.2
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://10.0.2.2:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081,http://10.0.2.2:8000

# ── PostgreSQL (local dev) ──────────────────────────────────────
# In production (Render), set DATABASE_URL instead — see render.yaml,
# which wires it automatically from the managed Postgres instance.
DB_ENGINE=postgres
POSTGRES_DB=tibasafari
POSTGRES_USER=tibasafari
POSTGRES_PASSWORD=tibasafari
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Redis (WebSockets + Cache) ─────────────────────────────────
# In production (Render) REDIS_URL is wired automatically from render.yaml;
# CHANNEL_LAYERS_REDIS_URL falls back to REDIS_URL if unset.
REDIS_URL=redis://localhost:6379/0
CHANNEL_LAYERS_REDIS_URL=redis://localhost:6379/1

# ── Render (production only, set automatically by render.yaml) ──
# RENDER_EXTERNAL_HOSTNAME=tibasafari-backend.onrender.com

# ── JWT ────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=14

# ── Throttling ─────────────────────────────────────────────────
ANON_THROTTLE_RATE=100/hour
USER_THROTTLE_RATE=1000/hour

# ── Email ──────────────────────────────────────────────────────
# Set backend to smtp.EmailBackend in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@tibasafari.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Tiba Safari <noreply@tibasafari.com>

# ── Fare Calculation ───────────────────────────────────────────
FARE_BASE_RATE=2.50
FARE_PER_KM=1.20
FARE_PER_MINUTE=0.25
FARE_MINIMUM=8.00
FARE_WHEELCHAIR_SURCHARGE=5.00

# ── Social sign-in (patient_app) ────────────────────────────────
# Comma-separated OAuth client IDs. Leave empty to disable that provider.
# Google: Cloud Console → APIs & Services → Credentials → OAuth client ID
#   (include the Web, Android, and iOS client IDs you create — all are
#   valid "aud" values for tokens minted for this app).
GOOGLE_OAUTH_CLIENT_IDS=
# Apple: Developer Portal → Identifiers → Services ID (and/or the app's
#   Bundle ID for native Sign in with Apple).
APPLE_SIGN_IN_CLIENT_IDS=
